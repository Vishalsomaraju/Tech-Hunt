# ============================================================================
# TECH HUNT Server — Environment Variables (Production Template)
# Copy to .env and fill in real values.
# ============================================================================

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/techhunt?sslmode=require

# JWT signing secret — must be at least 32 characters (required)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_SECRET

# Port the HTTP + WebSocket server listens on (default: 3001)
PORT=3001

# Allowed CORS origin (your client URL)
CORS_ORIGIN=https://your-app.vercel.app

# Node environment
NODE_ENV=production
